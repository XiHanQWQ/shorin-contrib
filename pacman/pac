#!/usr/bin/env bash
# 描述： Pacman/AUR安装软件的TUI
# Description: Pacman/AUR pkg installation TUI 
# ==============================================================================
# 启用严格的错误处理机制
set -euo pipefail

# 记录初始语言环境，并强制 C locale 确保 awk 解析的一致性
ORIGINAL_LANG="${LC_ALL:-${LC_MESSAGES:-${LANG:-C}}}"
export LC_ALL=C

# --- 0. 内部生成器拦截 (由 fzf reload 或后台进程触发) ---
if [[ "${1:-}" == "--generate-list" ]]; then
    FORCE_REFRESH="$2"
    INSTALLED_LIST="$3"
    AUR_CACHE="$4"
    AUR_FILTER="$5"
    MSG_INSTALLED="$6"
    CACHE_TIME=3600

    AWK_CMD='
        FNR==NR { installed[$1]=1; next }
        {
            status = ($2 in installed) ? ci " ✔ " label r : ""
            
            # 先打印带有颜色的源，紧接着打印重置符 \033[0m
            printf "%s%s%s", c, $1, r
            
            # 【修复】：将对齐宽度从 11 调大到 16，确保足以容纳 "archlinuxcn" 等较长源名并留出空格
            for(i=length($1); i<16; i++) printf " "
            
            # 【修复】：将包名的占位从 %-30s 增大到 %-35s，让排版更宽松
            printf "%-35s %-20s %s\n", $2, $3, status
        }
    '

    # 1. 优先输出本地已安装包的状态列表（确保界面立刻有反应）
    pacman -Qq > "$INSTALLED_LIST" || true

    # 2. 官方源数据
    pacman -Sl | awk -v c='\033[34m' -v ci='\033[32m' -v r='\033[0m' \
        -v label="$MSG_INSTALLED" \
        "$AWK_CMD" "$INSTALLED_LIST" -

    # 3. AUR 数据逻辑优化
    NEED_UPDATE=false
    if [[ "$FORCE_REFRESH" == true ]] || [[ ! -s "$AUR_CACHE" ]]; then
        NEED_UPDATE=true
    elif [[ $(find "$AUR_CACHE" -mmin +$((CACHE_TIME / 60)) 2>/dev/null) ]]; then
        NEED_UPDATE=true
    fi

    if [[ "$NEED_UPDATE" == true ]]; then
        # 核心改进：先下载到临时文件，避免直接重定向清空旧缓存
        TEMP_AUR="${AUR_CACHE}.tmp"
        if curl -sLf --connect-timeout 5 https://aur.archlinux.org/packages.gz | zcat > "$TEMP_AUR" 2>/dev/null; then
            mv "$TEMP_AUR" "$AUR_CACHE"
        else
            rm -f "$TEMP_AUR"
        fi
    fi

    # 只要缓存文件大于 0，就显示它
    if [[ -s "$AUR_CACHE" ]]; then
        grep -vE "$AUR_FILTER" "$AUR_CACHE" 2>/dev/null | \
        awk '{print "aur", $1, "-"}' | \
        awk -v c='\033[35m' -v ci='\033[32m' -v r='\033[0m' \
            -v label="$MSG_INSTALLED" \
            "$AWK_CMD" "$INSTALLED_LIST" -
    fi
    exit 0
fi

# --- 1. 环境与基础配置 ---
SHOW_HELP=false
FORCE_REFRESH=false
CHECK_ONLY=false
QUERY_ARGS=()
OPENCODE_MODEL="${PAC_OPENCODE_MODEL:-opencode/deepseek-v4-flash-free}"

# 获取脚本自身的绝对路径，确保在 fzf 子进程 reload 时能准确自我调用
SCRIPT_PATH="$(realpath "$0" 2>/dev/null || echo "$0")"

# --- 2. 参数解析 ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            SHOW_HELP=true
            shift
            ;;
        --refresh|-y)
            FORCE_REFRESH=true
            shift
            ;;
        --check|-c)
            CHECK_ONLY=true
            shift
            ;;
        --ai-model)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --ai-model requires a model value." >&2
                exit 1
            fi
            OPENCODE_MODEL="${2:-}"
            shift 2
            ;;
        *)
            QUERY_ARGS+=("$1")
            shift
            ;;
    esac
done

